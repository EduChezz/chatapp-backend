generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(uuid()) @db.Uuid
  name         String    @db.VarChar(100)
  email        String    @unique @db.VarChar(150)
  password     String    @db.VarChar(255)
  avatar_color String?   @default("#3b82f6") @db.VarChar(20)
  bio          String?   @default("")
  status       String?   @default("en línea") @db.VarChar(30)
  created_at   DateTime? @default(now()) @db.Timestamp(6)

  // Relaciones
  messages     Message[]
  reactions    Reaction[]
  memberships  ConversationMember[]

  @@map("users")
}

model Conversation {
  id         String    @id @default(uuid()) @db.Uuid
  name       String?   @db.VarChar(100)
  is_group   Boolean?  @default(false)
  color      String?   @default("#3b82f6") @db.VarChar(20)
  created_at DateTime? @default(now()) @db.Timestamp(6)

  // Relaciones
  messages   Message[]
  members    ConversationMember[]

  @@map("conversations")
}

model ConversationMember {
  conversation_id String @db.Uuid
  user_id         String @db.Uuid

  // Relaciones
  conversation    Conversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)
  user            User         @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@id([conversation_id, user_id])
  @@map("conversation_members")
}

model Message {
  id              String    @id @default(uuid()) @db.Uuid
  conversation_id String    @db.Uuid
  sender_id       String?   @db.Uuid
  type            String?   @default("text") @db.VarChar(20)
  content         String    @db.Text
  file_name       String?   @db.VarChar(255)
  file_size       String?   @db.VarChar(50)
  read            Boolean?  @default(false)
  edited          Boolean?  @default(false)
  created_at      DateTime? @default(now()) @db.Timestamp(6)

  // Relaciones
  conversation    Conversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)
  sender          User?        @relation(fields: [sender_id], references: [id], onDelete: SetNull)
  reactions       Reaction[]

  @@map("messages")
}

model Reaction {
  id         String   @id @default(uuid()) @db.Uuid
  emoji      String
  user_id    String   @db.Uuid
  message_id String   @db.Uuid
  
  // Relaciones
  message    Message  @relation(fields: [message_id], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, message_id, emoji])
  @@map("reactions")
}